# Template: copy to .env and fill in your real values.
# Do NOT put real passwords in this file (it may be committed to Git).

# Required: your Postgres connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/cwk_hub"

# Production: use a strong random JWT secret; never commit the real value
# JWT_SECRET=your-secret-key

# Production: restrict CORS to your frontend origin (e.g. https://hub.codewithkids.co.ke)
# CORS_ORIGIN=https://your-frontend-domain.com

# Optional: API port (default 3001)
# PORT=3001

# Optional: NODE_ENV=production (enables CORS restriction when CORS_ORIGIN is set)
# NODE_ENV=development
