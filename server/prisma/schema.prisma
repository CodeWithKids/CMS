// CWK Hub API – PostgreSQL schema
// Apply schema: npx prisma db push   (use this if migrate dev fails with P3014 shadow DB permission)
// Migrations:  npx prisma migrate dev   (requires DB user with CREATEDB permission)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id
  name             String
  role             String
  email            String?  @unique
  contactPhone     String?
  status           String?  @default("active")
  organizationId   String?
  membershipStatus String?
  avatarId         String?
  passwordHash     String?  // bcrypt hash; null = no login
  createdAt        DateTime @default(now())

  @@map("users")
}

model Term {
  id        String   @id
  name      String
  startDate String
  endDate   String
  isCurrent Boolean  @default(false)

  @@map("terms")
}

model Learner {
  id              String   @id
  firstName       String
  lastName        String
  dateOfBirth     String
  school          String
  enrolmentType   String
  programType     String
  membershipStatus String?
  userId          String?
  parentName      String?
  parentPhone     String?
  parentEmail     String?
  organizationId  String?
  status         String   @default("active")
  gender         String?
  joinedAt        String?

  @@map("learners")
}

model Class {
  id                      String   @id
  name                    String
  program                 String
  ageGroup                String
  location                String
  educatorId              String
  termId                  String
  learnerIds              String[]
  capacity                Int?
  schoolOrOrganisationName String?  // school or organisation the class belongs to
  trackId                 String?  // optional primary learning track (matches LearningTrack.id)

  @@map("classes")
}

model Session {
  id                   String   @id
  classId              String
  date                 String
  startTime            String
  endTime              String
  topic                String
  sessionType          String
  durationHours        Float
  learningTrack        String
  termId               String
  leadEducatorId       String
  assistantEducatorIds String[]

  attendance AttendanceRecord[]

  @@map("sessions")
}

model SessionReport {
  id                     String   @id
  sessionId              String   @unique
  status                 String   // draft | submitted
  leadEducatorId         String
  assistantEducatorIds   String[]
  date                   String
  duration               String
  sessionType            String
  schoolOrOrganizationName String
  totalLearners          Int
  learningTrack          String
  durationHours          Float
  femaleCount            Int
  maleCount              Int
  highlights             String[]
  objectivesMet          String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("session_reports")
}

model AttendanceRecord {
  id         String   @id
  sessionId  String
  learnerId  String
  status     String   // present | absent | late
  stars      Int?
  notes      String?
  markedAt   DateTime?
  markedBy   String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, learnerId])
  @@map("attendance_records")
}

model Organisation {
  id            String  @id
  name          String
  type          String
  contactPerson String
  contactEmail  String?
  contactPhone  String?
  location      String

  @@map("organisations")
}

model PendingSignup {
  id         String   @id
  signupType String   // school | organisation | miradi | parent
  payload    Json     // form data + passwordHash
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  @@map("pending_signups")
}

model FinanceInvoice {
  id             String   @id
  payerType      String
  payerId        String
  learnerId      String?
  organisationId String?
  termId         String
  programmeId    String?
  trackId        String?
  grossAmount    Float
  discountAmount Float    @default(0)
  netAmount      Float
  amountPaid     Float    @default(0)
  balance        Float
  currency       String
  dueDate        String
  issueDate      String
  status         String
  notes          String?
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime?
  updatedBy      String?

  payments Payment[]

  @@map("finance_invoices")
}

model Payment {
  id          String   @id
  invoiceId   String
  amount     Float
  method     String
  reference  String?
  date        String
  recordedBy  String
  createdAt   DateTime

  invoice FinanceInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Event {
  id          String   @id
  slug        String   @unique
  title       String
  description String?
  startDate   String
  endDate     String?
  location    String
  capacity    Int?
  price       Float?
  tracks      String[]
  status      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model FinanceEducatorPayment {
  id          String   @id
  educatorId  String
  period      String
  type        String
  amount      Float
  status      String
  datePaid    String?
  notes       String?

  @@map("finance_educator_payments")
}

model InventoryItem {
  id                    String   @id
  name                  String
  category              String
  status                String
  serialNumber          String?
  purchasedAt           String?
  checkedOutByEducatorId String?
  assignedEducatorId    String?
  checkedOutAt          String?
  dueAt                 String?
  notes                 String?

  @@map("inventory_items")
}

model LessonPlanTemplate {
  id              String   @id
  learningTrackId String
  title           String
  payload         Json
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("lesson_plan_templates")
}

model LessonPlanInstance {
  id          String   @id
  sessionId   String
  templateId  String?
  status      String
  payload     Json
  educatorId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lesson_plan_instances")
}

model CoachingNote {
  id        String   @id
  educatorId String
  authorId  String
  date      String
  text      String
  trackRef  String?
  sessionId String?
  createdAt DateTime @default(now())

  @@map("coaching_notes")
}

model EducatorBadge {
  id         String @id
  educatorId String
  badgeId    String
  trackId    String?
  earnedAt   String

  @@map("educator_badges")
}

model LearnerBadgeAward {
  id        String @id
  learnerId String
  sessionId String
  badgeId   String
  awardedAt String
  awardedBy String

  @@map("learner_badge_awards")
}

// Settings reference data (admin-managed)
model Program {
  id          String   @id
  name        String
  description String?
  trackId     String?  // optional primary learning track (matches LearningTrack.id)

  @@map("programs")
}

// Focus areas group learning tracks (e.g. Programming & Development, Experiments & Applied Science)
model FocusArea {
  id     String @id
  name   String
  slug   String @unique
  order  Int    @default(0)
  tracks LearningTrack[]

  @@map("focus_areas")
}

// Learning track (e.g. Game Design, Python); Session.learningTrack / LessonPlanTemplate.learningTrackId store this id
model LearningTrack {
  id           String     @id
  name         String
  slug         String     @unique
  focusAreaId  String
  focusArea    FocusArea  @relation(fields: [focusAreaId], references: [id], onDelete: Restrict)
  level        String?
  order        Int        @default(0)

  @@map("learning_tracks")
}

model Location {
  id      String  @id
  name    String
  address String?

  @@map("locations")
}

model AgeGroup {
  id     String @id
  name   String
  minAge Int?
  maxAge Int?

  @@map("age_groups")
}

model IncomeSource {
  id   String  @id
  name String
  code String?

  @@map("income_sources")
}

model ExpenseCategory {
  id   String  @id
  name String
  code String?

  @@map("expense_categories")
}

